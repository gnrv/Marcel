{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(lldb) Launch",
            "type": "lldb-dap",
            "request": "launch",
            "program": "${workspaceFolder}/build/quicktex",
            "args": [],
            "cwd": "${workspaceFolder}/build",
            "env": []
        },
        {
            "name": "(gdb) Launch",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/quicktex",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable debuginfod",
                    "text": "set debuginfod enabled on",
                    "ignoreFailures": false
                },
                {
                    "description": "Set debuginfod URL explicitly",
                    "text": "set debuginfod urls https://debuginfod.ubuntu.com"
                },
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    // For this to work, you need to
                    // cd ${workspaceFolder}/build
                    // mkdir src
                    // apt source libglfw3
                    "description": "Set path substitution for GLFW source",
                    "text": "set substitute-path ./build-x11/src ${workspaceFolder}/build/src/glfw3-3.3.6",
                    "ignoreFailures": false
                }
            ]
        }

    ]
}
